{
  "name": "hermes-console",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "pnpm --filter @hermes-console/runtime build && pnpm --parallel --filter @hermes-console/runtime --filter @hermes-console/api --filter @hermes-console/web dev",
    "build": "pnpm --filter @hermes-console/runtime build && pnpm --filter @hermes-console/api build && pnpm --filter @hermes-console/web build",
    "start": "pnpm --filter @hermes-console/api start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @hermes-console/runtime build && pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.1"
  }
}
